# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database (Neon PostgreSQL) — paste YOUR own connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
PGSSL=true

# Auth — generate your own long random secrets
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Gmail follow-ups (free) — use a Google App Password (NOT your normal password)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Admin account created by "npm run clean"
ADMIN_EMAIL=your@gmail.com
ADMIN_PASSWORD=change_me

# Daily follow-up email time (cron)
REMINDER_CRON=0 9 * * *
